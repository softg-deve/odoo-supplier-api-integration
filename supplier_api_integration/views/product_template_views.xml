<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="view_product_template_form_inherit_api" model="ir.ui.view">
        <field name="name">product.template.form.inherit.api</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
          
            <xpath expr="//page[@name='inventory']//group[@name='group_lots_and_weight']" position="inside">
                <field name="supplier_api_id" invisible="1"/>
                <field name="weight" 
                       string="Weight (kg)" 
                       attrs="{'invisible': [('supplier_api_id', '=', False)]}"
                       help="Product weight from supplier (in kilograms)"/>
                <field name="weight_uom_name" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_product_supplierinfo_tree_inherit_api" model="ir.ui.view">
        <field name="name">product.supplierinfo.tree.inherit.api</field>
        <field name="model">product.supplierinfo</field>
        <field name="inherit_id" ref="product.product_supplierinfo_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='price']" position="after">
                <field name="api_stock_quantity" 
                       string="📦 Stock" 
                       readonly="1" 
                       decoration-success="api_stock_quantity &gt; 0"
                       decoration-danger="api_stock_quantity == 0"/>
            </xpath>
        </field>
    </record>
    
    <record id="view_product_template_search_inherit_api" model="ir.ui.view">
        <field name="name">product.template.search.inherit.api</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']" position="after">
                <separator/>
                <field name="supplier_api_id" invisible="1"/>
                <filter string="From API TME" 
                        name="from_api" 
                        domain="[('supplier_id', 'in', ['tme'])]"/>
                        
            </xpath>
            
            <xpath expr="//group" position="inside">
                <field name="supplier_api_id" invisible="1"/>
                <filter string="Supplier API" 
                        name="group_supplier_api" 
                        context="{'group_by': 'supplier_id'}"/>
                        
                <filter string="API Category" 
                        name="group_api_category" 
                        context="{'group_by': 'supplier_api_category_id'}"/>
            </xpath>
        </field>
    </record>
    
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_preview_wizard_form" model="ir.ui.view">
        <field name="name">product.preview.wizard.form</field>
        <field name="model">product.preview.wizard</field>
        <field name="arch" type="xml">
            <form string="Preview Products from API">
                <header>
                    <button name="action_import_selected" 
                            string="✅ Import Selected" 
                            type="object" 
                            class="btn-primary"
                            confirm="Import selected products?"/>
                    
                    <button name="action_select_all" 
                            string="Select All New" 
                            type="object" 
                            class="btn-secondary"/>
                    
                    <button name="action_deselect_all" 
                            string="Deselect All" 
                            type="object" 
                            class="btn-secondary"/>
                </header>
                
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="category_id" readonly="1"/>
                        </h1>
                        <h3 class="text-muted">
                            <field name="supplier_id" readonly="1"/>
                        </h3>
                    </div>
                
                    <group>
                        <group>
                            <field name="total_products" readonly="1"/>
                            <field name="selected_products" readonly="1" 
                                   class="text-success font-weight-bold"/>
                        </group>
                        <group>
                            <field name="existing_products" readonly="1"
                                   class="text-info font-weight-bold"/>
                        </group>
                    </group>
                    
                    <group string="💰 Pricing Configuration">
                        <div class="o_row">
                            <field name="show_sale_price" 
                                   widget="boolean_toggle"
                                   string="Enable Sale Price for Products"
                                   class="oe_inline"/>
                        </div>
                    </group>
                    
                    <notebook>
                        <page string="📦 Products Preview" name="products">
                            <field name="line_ids" nolabel="1">
                                <tree decoration-success="selected==True" 
                                      decoration-muted="exists_in_odoo==True"
                                      create="false" delete="false">
                                    
                                    <field name="image_preview" widget="image" options="{'size': [50, 50]}"/>
                                    
                                    <field name="exists_in_odoo" 
                                           string="✅ In Odoo" 
                                           widget="boolean"/>
                                    
                                    <field name="selected" 
                                           widget="boolean_toggle"
                                           attrs="{'readonly': [('exists_in_odoo', '=', True)]}"/>
                                    
                                    <button name="action_open_product" 
                                            string="Open" 
                                            type="object" 
                                            icon="fa-external-link"
                                            class="btn-link"
                                            attrs="{'invisible': [('exists_in_odoo', '=', False)]}"/>
                                    
                                    <field name="symbol"/>
                                    <field name="name"/>
                                    <field name="manufacturer" optional="show"/>
                                    <field name="barcode" optional="show"/>
                                    
                                    <field name="price" 
                                           string="💰 Cost" 
                                           widget="monetary" 
                                           options="{'currency_field': 'currency'}"/>
                                    
                                    <field name="sale_price" 
                                           string="💵 Sale Price (if enabled)" 
                                           widget="monetary" 
                                           options="{'currency_field': 'currency'}"
                                           decoration-muted="sale_price == 0"
                                           decoration-success="sale_price &gt; 0"/>
                                    
                                    <field name="currency" invisible="1"/>
                                    
                                    <field name="stock_quantity" 
                                           string="📦 Stock"
                                           decoration-success="stock_quantity &gt; 0"
                                           decoration-danger="stock_quantity == 0"/>
                                    
                                    <field name="photo_url" invisible="1"/>
                                    <field name="odoo_product_id" invisible="1"/>
                                    
                                </tree>
                            </field>
                        </page>
                        
                    
                    </notebook>
                </sheet>
                
                <footer>
                    <button string="✅ Import Selected" 
                            name="action_import_selected" 
                            type="object" 
                            class="btn-primary"
                            confirm="Import selected products?"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>